# kr-multi-market environment variables
# Copy this file to .env.local and fill in actual values
# NEVER commit .env.local to git (gitignored)

# Bearer token for /api/internal/health (generate: openssl rand -hex 32)
HEALTH_TOKEN=

# Server config
PORT=3001
NODE_ENV=development

# Hyperliquid WebSocket (allMids subscription) — 1초 미만 실시간 HL 가격
# default: false (REST polling 1s cache)
# realtime 권장: HL_USE_WS=true (개발/로컬). 서버 재시작 필요.
HL_USE_WS=false

# === v0.4.2 + v0.5.0 ===

# Yahoo Tier-4 fallback (v0.4.2) — Yahoo rate limit 시 자동 fallback (ETF 전용)
# 종목 검색 영문 Tier 1 (v0.5.0) — Finnhub /search (NASDAQ/NYSE). 미설정 시 영문 검색 비활성.
# 가입: https://finnhub.io/register (무료 60/min)
# FINNHUB_TOKEN=

# Polygon.io 옵셔널 — NQ 추가 source. 무료 5/min (paid 권장).
# 가입: https://polygon.io/dashboard/api-keys
# POLYGON_API_KEY=

# TwelveData 옵셔널 — NQ 추가 source. 무료 800/day (paid 권장).
# 가입: https://twelvedata.com/account/api-keys
# TWELVEDATA_API_KEY=

# v2 backlog (KIS deferred per user decision Q16=B):
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_ACCOUNT=
