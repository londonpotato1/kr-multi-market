# kr-multi-market environment variables
# Copy this file to .env.local and fill in actual values
# NEVER commit .env.local to git (gitignored)

# Internal health endpoint auth token
# Generate with: openssl rand -hex 32
HEALTH_TOKEN=

# Server config
PORT=3001
NODE_ENV=development

# Optional: Yahoo fallback if rate-limited (sign up at https://finnhub.io/)
# FINNHUB_TOKEN=

